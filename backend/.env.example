# ───── App ─────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_PORT=8080
APP_NAME=interview-question-002
APP_ALLOWED_ORIGINS=http://localhost:5173

# ───── Database (Postgres) ────────────────────────
# For SSH-tunnelled DB, point host/port at the local forwarded port:
#   ssh -L 5433:127.0.0.1:5432 <user>@<bastion>
DB_HOST=localhost
DB_PORT=5433
DB_USER=keyvc
DB_PASSWORD=keyvc_dev_password
DB_NAME=test_tcc
DB_SSLMODE=disable
DB_MAX_OPEN=25
DB_MAX_IDLE=10

# ───── JWT (RS256) ────────────────────────────────
# Generate the keypair with: go run ./cmd/keys   (or `make keys`)
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_TTL=60m
JWT_ISSUER=example.com

# ───── Logging ────────────────────────────────────
LOG_LEVEL=info                 # debug | info | warn | error
LOG_FORMAT=console             # json | console
