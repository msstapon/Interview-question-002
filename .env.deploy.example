# ─────────────────────────────────────────────────────────────────────────────
# Production env for the VPS docker-compose stack.
# Copy to the VPS as:  /opt/interview-question-002/deployments/docker/.env
# (never commit the real file — it holds the DB password)
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production
APP_PORT=8080
APP_NAME=interview-question-002
# Same-origin via Caddy; set to your public URL (or the VPS IP) for clarity.
APP_ALLOWED_ORIGINS=http://YOUR_VPS_IP

# Postgres runs as a container on the internal network (service name: postgres).
DB_HOST=postgres
DB_PORT=5432
DB_USER=keyvc
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=test_tcc
DB_SSLMODE=disable

# JWT keypair is generated into a docker volume by the `keygen` service.
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_TTL=60m
JWT_ISSUER=example.com

LOG_LEVEL=info
LOG_FORMAT=json

# Caddy entry address:
#   a domain  → automatic HTTPS  (e.g. SITE_ADDRESS=app.example.com)
#   ":80"     → plain HTTP on the VPS IP (no domain)
SITE_ADDRESS=:80

# Host ports for Caddy. Override only if 80/443 are already used on the VPS
# (e.g. another project's reverse proxy). Default 80/443.
# HTTP_PORT=8081
# HTTPS_PORT=8443

# GHCR image coordinates (the deploy workflow also exports these).
GHCR_OWNER=msstapon
TAG=latest
